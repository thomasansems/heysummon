{
  "name": "@heysummon/claude-code",
  "version": "0.1.0",
  "description": "Claude Code plugin and TypeScript tool for summoning a human expert via HeySummon when an agent is stuck, needs approval, or lacks context.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "heysummon-summon": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "skills",
    ".claude-plugin",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\""
  },
  "dependencies": {
    "@heysummon/consumer-sdk": "^0.2.20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "msw": "^2.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "heysummon",
    "human-in-the-loop",
    "hitl",
    "ai-agent",
    "agent-tool"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/heysummon/claude-code.git"
  },
  "homepage": "https://github.com/heysummon/claude-code#readme",
  "bugs": {
    "url": "https://github.com/heysummon/claude-code/issues"
  }
}
