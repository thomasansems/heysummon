// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`buildInstallCommand — snapshot all skill channels > snapshot: claudecode 1`] = `
"if [ -f '.claude/skills/heysummon/.env' ]; then
  existing=$( (set -a; . '.claude/skills/heysummon/.env'; printf '%s' "$HEYSUMMON_API_KEY") 2>/dev/null || printf '' )
  if [ "$existing" = 'hs_cli_abc123' ]; then
    echo "HeySummon already configured at .claude/skills/heysummon/.env — nothing to do."
    exit 0
  fi
  if [ "\${HEYSUMMON_FORCE:-}" != "1" ]; then
    echo "Refusing to overwrite existing HeySummon install at .claude/skills/heysummon/.env (different apiKey)." >&2
    echo "To replace, re-run with HEYSUMMON_FORCE=1." >&2
    exit 1
  fi
fi
npm install @heysummon/consumer-sdk && \\
mkdir -p .claude/skills/heysummon/scripts && \\
for f in ask.sh sdk.sh setup.sh add-expert.sh list-experts.sh check-status.sh; do \\
  curl -fsSL "https://hs.example.com/api/v1/skill-scripts/claudecode?file=$f" \\
    -o .claude/skills/heysummon/scripts/$f && chmod +x .claude/skills/heysummon/scripts/$f; \\
done && \\
curl -fsSL "https://hs.example.com/api/v1/skill-scripts/claudecode?file=SKILL.md" \\
  -o .claude/skills/heysummon/SKILL.md && \\
printf '%s' '' | base64 -d > .claude/skills/heysummon/.env && \\
HEYSUMMON_BASE_URL='https://hs.example.com' bash .claude/skills/heysummon/scripts/add-expert.sh 'hs_cli_abc123' 'Thomas' && \\
echo "Verifying connection..." && \\
curl -sf "https://hs.example.com/api/v1/whoami" \\
  -H "x-api-key: hs_cli_abc123" > /dev/null && \\
echo "HeySummon skill installed and connected successfully.""
`;

