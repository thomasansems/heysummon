// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`setup copy / install command — drift snapshots > claudecode / noContext / global 1`] = `
{
  "copyText": "HeySummon Setup
---
Connect this AI agent to a human expert via HeySummon.

INSTALLATION (Claude Code):

Step 1. Add the HeySummon marketplace (one-time):
  /plugin marketplace add thomasansems/heysummon

Step 2. Install the plugin (one-time):
  /plugin install heysummon@client

Step 3. Configure with your setup link:
  /heysummon:setup https://example.heysummon.test/setup/st_FIXED_TOKEN

ALTERNATIVE (any terminal):
  curl -sf "https://example.heysummon.test/api/v1/setup/st_FIXED_TOKEN/command" | jq -r '.installCommand' | bash

Setup link (valid 24 hours): https://example.heysummon.test/setup/st_FIXED_TOKEN",
  "installCommand": "if [ -f '.claude/skills/heysummon/.env' ]; then
  existing=$( (set -a; . '.claude/skills/heysummon/.env'; printf '%s' "$HEYSUMMON_API_KEY") 2>/dev/null || printf '' )
  if [ "$existing" = 'hs_cli_FIXED_API_KEY' ]; then
    echo "HeySummon already configured at .claude/skills/heysummon/.env — nothing to do."
    exit 0
  fi
  if [ "\${HEYSUMMON_FORCE:-}" != "1" ]; then
    echo "Refusing to overwrite existing HeySummon install at .claude/skills/heysummon/.env (different apiKey)." >&2
    echo "To replace, re-run with HEYSUMMON_FORCE=1." >&2
    exit 1
  fi
fi
npm install -g @heysummon/consumer-sdk && \\
mkdir -p .claude/skills/heysummon/scripts && \\
for f in ask.sh sdk.sh setup.sh add-expert.sh list-experts.sh check-status.sh; do \\
  curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/claudecode?file=$f" \\
    -o .claude/skills/heysummon/scripts/$f && chmod +x .claude/skills/heysummon/scripts/$f; \\
done && \\
curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/claudecode?file=SKILL.md" \\
  -o .claude/skills/heysummon/SKILL.md && \\
printf '%s' 'SEVZU1VNTU9OX0JBU0VfVVJMPSdodHRwczovL2V4YW1wbGUuaGV5c3VtbW9uLnRlc3QnCkhFWVNVTU1PTl9BUElfS0VZPSdoc19jbGlfRklYRURfQVBJX0tFWScKSEVZU1VNTU9OX1RJTUVPVVQ9JzkwMCcKSEVZU1VNTU9OX1BPTExfSU5URVJWQUw9JzMnCkhFWVNVTU1PTl9USU1FT1VUX0ZBTExCQUNLPSdwcm9jZWVkX2NhdXRpb3VzbHknCg==' | base64 -d > .claude/skills/heysummon/.env && \\
HEYSUMMON_BASE_URL='https://example.heysummon.test' bash .claude/skills/heysummon/scripts/add-expert.sh 'hs_cli_FIXED_API_KEY' 'ExampleExpert' && \\
echo "Verifying connection..." && \\
curl -sf "https://example.heysummon.test/api/v1/whoami" \\
  -H "x-api-key: hs_cli_FIXED_API_KEY" > /dev/null && \\
echo "HeySummon skill installed and connected successfully."",
}
`;

