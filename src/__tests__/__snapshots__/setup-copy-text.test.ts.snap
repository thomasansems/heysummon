  if [ "\${HEYSUMMON_FORCE:-}" != "1" ]; then
    echo "Refusing to overwrite existing HeySummon install at .cursor/skills/heysummon/.env (different apiKey)." >&2
    echo "To replace, re-run with HEYSUMMON_FORCE=1." >&2
    exit 1
  fi
fi
npm install -g @heysummon/consumer-sdk && \\
mkdir -p .cursor/skills/heysummon/scripts && \\
for f in ask.sh sdk.sh setup.sh add-expert.sh list-experts.sh check-status.sh; do \\
  curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/cursor?file=$f" \\
    -o .cursor/skills/heysummon/scripts/$f && chmod +x .cursor/skills/heysummon/scripts/$f; \\
done && \\
curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/cursor?file=SKILL.md" \\
  -o .cursor/skills/heysummon/SKILL.md && \\
printf '%s' 'SEVZU1VNTU9OX0JBU0VfVVJMPSdodHRwczovL2V4YW1wbGUuaGV5c3VtbW9uLnRlc3QnCkhFWVNVTU1PTl9BUElfS0VZPSdoc19jbGlfRklYRURfQVBJX0tFWScKSEVZU1VNTU9OX1RJTUVPVVQ9JzkwMCcKSEVZU1VNTU9OX1BPTExfSU5URVJWQUw9JzMnCkhFWVNVTU1PTl9USU1FT1VUX0ZBTExCQUNLPSdwcm9jZWVkX2NhdXRpb3VzbHknCg==' | base64 -d > .cursor/skills/heysummon/.env && \\
HEYSUMMON_BASE_URL='https://example.heysummon.test' bash .cursor/skills/heysummon/scripts/add-expert.sh 'hs_cli_FIXED_API_KEY' 'ExampleExpert' && \\
echo "Verifying connection..." && \\
curl -sf "https://example.heysummon.test/api/v1/whoami" \\
  -H "x-api-key: hs_cli_FIXED_API_KEY" > /dev/null && \\
echo "HeySummon skill installed and connected successfully."",
}
`;

