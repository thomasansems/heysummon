generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  password           String?
  name               String?
  image              String?
  role               String    @default("provider") // "admin" | "provider" | "readonly"
  onboardingComplete Boolean   @default(false)
  expertise          String?
  notificationPref   String    @default("email")
  telegramChatId     String?
  apiKeys            ApiKey[]
  providers          UserProfile[]
  requests           HelpRequest[] @relation("ExpertRequests")
  accounts           Account[]
  sessions           Session[]
  certificates       ClientCertificate[]
  consents           UserConsent[]
  dataRequests       DataRequest[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id               String            @id @default(cuid())
  name             String
  key              String            @unique
  userId           String
  isActive         Boolean           @default(true)
  timezone         String?
  quietHoursStart  String?
  quietHoursEnd    String?
  availableDays    String?
  digestTime       String?
  deviceSecret     String?
  machineId        String?
  tagline          String?           // Optional upsell tagline appended to responses (max 160 chars)
  taglineEnabled   Boolean           @default(false)
  summonContext    String?           // Advisory text for AI: when to summon this provider (max 500 chars)
  phoneFirst       Boolean           @default(false) // If true, attempt phone call before chat
  phoneFirstIntegrationId String?    // Which voice integration to use for phone-first
  phoneFirstTimeout       Int        @default(30)    // Seconds to wait for phone pickup before fallback
  user             User              @relation(fields: [userId], references: [id])
  apiKeys          ApiKey[]
  channelProviders ChannelProvider[]
  ipEvents         IpEvent[]
  integrationConfigs ProviderIntegrationConfig[]
  missedRequests   MissedRequest[]
  createdAt        DateTime          @default(now())
}

model ChannelProvider {
  id              String       @id @default(cuid())
  profileId       String
  profile         UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type            String       // "openclaw" | "telegram" | "whatsapp"
  name            String
  isActive        Boolean      @default(true)
  config          String       @default("{}")  // JSON, type-specific
  pairingCode     String?      @unique
  pairingExpires  DateTime?
  paired          Boolean      @default(false)
  lastHeartbeat   DateTime?
  status          String       @default("disconnected")
  errorMessage    String?
  requests        HelpRequest[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([profileId])
  @@index([type])
}

model ApiKey {
  id                   String        @id @default(cuid())
  key                  String        @unique
  name                 String?
  userId               String
  user                 User          @relation(fields: [userId], references: [id])
  providerId           String?
  provider             UserProfile?  @relation(fields: [providerId], references: [id])
  isActive             Boolean       @default(true)
  deviceSecret         String?       // SHA-256 hash of device token (nullable for legacy keys)
  machineId            String?       // SHA-256 hash of machine fingerprint (auto-bound on first valid request)
  scope                String        @default("full")    // full|read|write|admin
  previousKeyHash      String?                            // SHA-256 of rotated-out key
  previousKeyExpiresAt DateTime?                           // 24h grace window
  allowedIps           String?                             // comma-separated CIDR/IPs
  rateLimitPerMinute   Int           @default(150)
  clientChannel        String?       // "openclaw" | "claudecode" | "codex" | "gemini" | "cursor"
  clientSubChannel     String?       // "telegram" | "whatsapp" (only for openclaw)
  lastPollAt           DateTime?     // Updated on every /api/v1/events/pending call — used for connection verification
  requests             HelpRequest[]
  ipEvents             IpEvent[]
  missedRequests       MissedRequest[]
  setupTokens          SetupToken[]
  createdAt            DateTime      @default(now())

  @@index([previousKeyHash])
}

model SetupToken {
  id            String   @id @default(cuid())
  token         String   @unique            // Opaque URL-safe token (st_xxxx)
  apiKeyId      String
  apiKey        ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  baseUrl       String
  channel       String                      // "openclaw" | "claudecode" | "codex" | "gemini" | "cursor"
  subChannel    String?                     // "telegram" | "whatsapp"
  providerName  String?
  summonContext String?              // Copied from provider profile at link-creation time
  timeout       Int      @default(900)
  pollInterval  Int      @default(3)
  globalInstall Boolean  @default(true)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([apiKeyId])
}

model IpEvent {
  id        String   @id @default(cuid())
  apiKeyId  String?
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  profileId String?
  profile   UserProfile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ip        String
  status    String   @default("pending") // "allowed" | "pending" | "blacklisted"
  attempts  Int      @default(1)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([apiKeyId, ip])
  @@unique([profileId, ip])
  @@index([apiKeyId])
  @@index([profileId])
}

model HelpRequest {
  id                     String    @id @default(cuid())
  refCode                String?   @unique
  apiKeyId               String
  apiKey                 ApiKey    @relation(fields: [apiKeyId], references: [id])
  expertId               String
  expert                 User      @relation("ExpertRequests", fields: [expertId], references: [id])

  // Legacy fields (v3 - keep for backward compatibility)
  // Deprecated: use Message model instead, but still accepted for backward compat
  messages               String?   // Deprecated
  question               String?   // Deprecated
  response               String?   // Deprecated
  consumerPublicKey      String?   // Deprecated: use consumerEncryptPubKey instead
  serverPublicKey        String?   // Deprecated
  serverPrivateKey       String?   // Deprecated
  respondedAt            DateTime?

  // v4: E2E encryption keys (X25519 + Ed25519)
  consumerSignPubKey     String?   // Consumer's Ed25519 signing public key
  consumerEncryptPubKey  String?   // Consumer's X25519 encryption public key
  providerSignPubKey     String?   // Provider's Ed25519 signing public key (after key exchange)
  providerEncryptPubKey  String?   // Provider's X25519 encryption public key (after key exchange)
  
  // Optional plaintext preview for notifications (max 200 chars)
  questionPreview        String?

  // Approval workflow
  requiresApproval       Boolean   @default(false)
  approvalDecision       String?   // "approved" | "denied" | null

  // Content safety (guard service)
  contentFlags           String?   // JSON array of safety flags from guard
  guardVerified          Boolean   @default(false) // true if content was validated by guard sidecar
  
  status                 String    @default("pending") // pending | active | closed | expired
  deliveredAt            DateTime? // When provider watcher acknowledged receipt
  consumerDeliveredAt    DateTime? // When consumer watcher last acknowledged messages
  expiresAt              DateTime  // createdAt + 72 hours
  closedAt               DateTime?

  // Delivery retry tracking
  deliveryStatus         String    @default("pending")   // pending | retrying | delivered | failed | cancelled
  deliveryRetryCount     Int       @default(0)
  deliveryLastAttemptAt  DateTime?
  deliveryNextRetryAt    DateTime?

  // HITL protocol: feedback/reward signals
  rating                 Int?      // Consumer quality rating (1-5)
  ratingFeedback         String?   // Optional text feedback from consumer
  ratedAt                DateTime?
  responseTimeMs         Int?      // Computed: respondedAt - createdAt in ms

  // HITL protocol: escalation tracking
  escalatedAt            DateTime? // Set when active-monitor escalates unacknowledged request
  
  // Phone-first call tracking
  phoneCallSid           String?   // Twilio Call SID
  phoneCallStatus        String?   // "initiated" | "ringing" | "answered" | "completed" | "no-answer" | "busy" | "failed"
  phoneCallResponse      String?   // Plaintext response collected from phone call
  phoneCallAt            DateTime? // When the call was initiated

  // Provider notification tracking
  notifiedProviderAt     DateTime? // When provider was notified (null = deferred due to unavailability)

  // Client timeout tracking
  clientTimedOutAt       DateTime? // When the consumer's blocking poll timed out without a response

  // Channel adapter fields
  channelProviderId      String?
  channelProvider        ChannelProvider? @relation(fields: [channelProviderId], references: [id])
  consumerChatId         String?   // External chat identifier (Telegram chat_id, etc.)
  consumerName           String?   // Display name from external channel

  // Relations
  messageHistory         Message[]

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Message {
  id          String      @id @default(cuid())
  requestId   String
  request     HelpRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  from        String      // "consumer" | "provider"
  
  // E2E encrypted message payload
  ciphertext  String      // AES-256-GCM encrypted (base64)
  iv          String      // Initialization vector (base64)
  authTag     String      // GCM authentication tag (base64)
  signature   String      // Ed25519 signature of ciphertext (base64)
  messageId   String      @unique // For HKDF salt + deduplication
  
  createdAt   DateTime    @default(now())
  
  @@index([requestId])
  @@index([messageId])
}

model ClientCertificate {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  fingerprint   String    @unique
  serialNumber  String    @unique
  notBefore     DateTime
  notAfter      DateTime
  revoked       Boolean   @default(false)
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([fingerprint])
}

model AuditLog {
  id        String   @id @default(cuid())
  eventType String
  userId    String?
  apiKeyId  String?
  ip        String?
  userAgent String?
  metadata  String?  // JSON string
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([userId])
}

model RateLimit {
  id      String   @id @default(cuid())
  keyId   String   @unique
  count   Int      @default(1)
  resetAt DateTime

  @@index([keyId])
  @@index([resetAt])
}

model Integration {
  id          String   @id @default(cuid())
  type        String   // "twilio" | future integrations
  category    String   // "voice" | "sms" | "email" — used to filter available integrations
  name        String   // Display name, e.g. "Twilio Voice"
  isActive    Boolean  @default(true)
  config      String   @default("{}") // JSON: system-level config (account SID, auth token)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  providerConfigs ProviderIntegrationConfig[]

  @@unique([type])
  @@index([category])
}

model ProviderIntegrationConfig {
  id              String       @id @default(cuid())
  profileId       String
  profile         UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  integrationId   String
  integration     Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  isActive        Boolean      @default(true)
  config          String       @default("{}") // JSON: provider-specific config (phone number, voice settings)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([profileId, integrationId])
  @@index([profileId])
  @@index([integrationId])
}

model ProviderMetrics {
  id                String   @id @default(cuid())
  providerId        String   @unique
  avgRating         Float?
  avgResponseTimeMs Float?
  totalResponded    Int      @default(0)
  totalExpired      Int      @default(0)
  reliability       Float?   // responded / (responded + expired)
  updatedAt         DateTime @updatedAt

  @@index([providerId])
}

model GdprSettings {
  id                   String   @id @default("singleton")
  enabled              Boolean  @default(false)
  anonymizeIps         Boolean  @default(true)   // Anonymize IPs in audit logs (last octet zeroed)
  retentionDays        Int      @default(90)     // Auto-delete data older than N days
  requireConsent       Boolean  @default(true)   // Require explicit user consent
  allowDataExport      Boolean  @default(true)   // Allow users to request data export
  allowDataDeletion    Boolean  @default(true)   // Allow users to request account deletion
  privacyPolicyUrl     String?                   // Link to privacy policy
  updatedAt            DateTime @updatedAt
}

model UserConsent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType String   // "data_processing" | "communications" | "analytics"
  granted     Boolean  @default(false)
  ipAddress   String?  // IP at time of consent (anonymized if GDPR enabled)
  userAgent   String?  // Browser at time of consent
  grantedAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, consentType])
  @@index([userId])
}

model DataRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // "export" | "deletion"
  status      String    @default("pending") // "pending" | "processing" | "completed" | "failed"
  result      String?   // JSON result or download path
  processedAt DateTime?
  expiresAt   DateTime? // Export download link expiry
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

model MissedRequest {
  id              String      @id @default(cuid())
  apiKeyId        String
  apiKey          ApiKey      @relation(fields: [apiKeyId], references: [id])
  providerId      String
  provider        UserProfile @relation(fields: [providerId], references: [id])
  nextAvailableAt DateTime?
  questionPreview String?     // First ~200 chars for dashboard context
  createdAt       DateTime    @default(now())

  @@index([apiKeyId])
  @@index([providerId])
  @@index([createdAt])
}
