  curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/gemini?file=$f" \\
    -o .gemini/skills/heysummon/scripts/$f && chmod +x .gemini/skills/heysummon/scripts/$f; \\
done && \\
curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/gemini?file=SKILL.md" \\
  -o .gemini/skills/heysummon/SKILL.md && \\
printf '%s' '' | base64 -d > .gemini/skills/heysummon/.env && \\
HEYSUMMON_BASE_URL='https://example.heysummon.test' bash .gemini/skills/heysummon/scripts/add-expert.sh 'hs_cli_FIXED_API_KEY' 'ExampleExpert' && \\
echo "Verifying connection..." && \\
curl -sf "https://example.heysummon.test/api/v1/whoami" \\
  -H "x-api-key: hs_cli_FIXED_API_KEY" > /dev/null && \\
echo "HeySummon skill installed and connected successfully."",
}
`;

exports[`setup copy / install command — drift snapshots > gemini / withContext / local 1`] = `
{
  "copyText": "HeySummon Setup
---
Connect this AI agent to a human expert via HeySummon.

IMPORTANT — SUMMONING GUIDELINES (save to memory):
The following guidelines define when and how to summon your human expert.
You MUST save these to your persistent memory before proceeding with any work.
These rules take priority over default autonomy settings.

Only summon when stuck or need approval.

INSTALLATION (Gemini CLI):

Run this in your project directory:
  curl -sf "https://example.heysummon.test/api/v1/setup/st_FIXED_TOKEN/command" | jq -r '.installCommand' | bash

This installs the HeySummon skill to .gemini/skills/heysummon and configures the connection.

Setup link (valid 24 hours): https://example.heysummon.test/setup/st_FIXED_TOKEN",
  "installCommand": "if [ -f '.gemini/skills/heysummon/.env' ]; then
  existing=$( (set -a; . '.gemini/skills/heysummon/.env'; printf '%s' "$HEYSUMMON_API_KEY") 2>/dev/null || printf '' )
  if [ "$existing" = 'hs_cli_FIXED_API_KEY' ]; then
    echo "HeySummon already configured at .gemini/skills/heysummon/.env — nothing to do."
    exit 0
  fi
  if [ "\${HEYSUMMON_FORCE:-}" != "1" ]; then
    echo "Refusing to overwrite existing HeySummon install at .gemini/skills/heysummon/.env (different apiKey)." >&2
    echo "To replace, re-run with HEYSUMMON_FORCE=1." >&2
    exit 1
  fi
fi
npm install @heysummon/consumer-sdk && \\
mkdir -p .gemini/skills/heysummon/scripts && \\
for f in ask.sh sdk.sh setup.sh add-expert.sh list-experts.sh check-status.sh; do \\
  curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/gemini?file=$f" \\
    -o .gemini/skills/heysummon/scripts/$f && chmod +x .gemini/skills/heysummon/scripts/$f; \\
done && \\
curl -fsSL "https://example.heysummon.test/api/v1/skill-scripts/gemini?file=SKILL.md" \\
  -o .gemini/skills/heysummon/SKILL.md && \\
printf '%s' '' | base64 -d > .gemini/skills/heysummon/.env && \\
HEYSUMMON_BASE_URL='https://example.heysummon.test' bash .gemini/skills/heysummon/scripts/add-expert.sh 'hs_cli_FIXED_API_KEY' 'ExampleExpert' && \\
echo "Verifying connection..." && \\
curl -sf "https://example.heysummon.test/api/v1/whoami" \\
  -H "x-api-key: hs_cli_FIXED_API_KEY" > /dev/null && \\
echo "HeySummon skill installed and connected successfully."",
}
`;

