exports[`setup copy / install command — drift snapshots > custom / noContext / global 1`] = `
{
  "copyText": "HeySummon Setup
---
Connect this AI agent to a human expert via HeySummon.

INSTALLATION (Custom — any runtime):

HeySummon has no runtime-specific skill for this client. Integrate with the
HTTP API directly, or use the TypeScript / JavaScript SDK.

Step 1. Fetch the generic recipe (env vars + sample request):
  curl -sf "https://example.heysummon.test/api/v1/setup/st_FIXED_TOKEN/command" | jq -r '.installCommand'

Step 2. For TypeScript / JavaScript runtimes, install the SDK:
  npm install @heysummon/consumer-sdk

The SDK handles key generation, end-to-end encryption, and polling for you.

Setup link (valid 24 hours): https://example.heysummon.test/setup/st_FIXED_TOKEN",
  "installCommand": "# HeySummon — generic HTTP recipe (works with any runtime)
export HEYSUMMON_BASE_URL="https://example.heysummon.test"
export HEYSUMMON_API_KEY="hs_cli_FIXED_API_KEY"

# Submit a help request. End-to-end encryption keys (signPublicKey / encryptPublicKey)
# are required — the @heysummon/consumer-sdk handles key generation, encryption, and
# polling for you. For raw HTTP, see https://example.heysummon.test/clients/custom for the full payload shape.
curl -sS -X POST "$HEYSUMMON_BASE_URL/api/v1/help" \\
  -H "Content-Type: application/json" \\
  -d "{\\"apiKey\\":\\"$HEYSUMMON_API_KEY\\",\\"question\\":\\"Ask your expert something\\"}"

# TypeScript / JavaScript runtimes: install the SDK (recommended):
#   npm install @heysummon/consumer-sdk",
}
`;

