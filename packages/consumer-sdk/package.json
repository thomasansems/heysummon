{
  "name": "@heysummon/consumer-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for HeySummon consumers (AI agents)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
